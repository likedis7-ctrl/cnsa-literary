rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isCnsaUser() {
      return request.auth != null
          && request.auth.token.email.matches('.*@cnsa\\.hs\\.kr');
    }

    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function roleNotChanged() {
      return !('role' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // 반응 배열 1개에 대해 본인 uid만 추가·삭제됐는지 검증 (헬퍼)
    function isValidArrayChange(newArr, oldArr, uid) {
      let added   = newArr.removeAll(oldArr);
      let removed = oldArr.removeAll(newArr);
      return (added.size()   == 0 || (added.size()   == 1 && added[0]   == uid))
          && (removed.size() == 0 || (removed.size() == 1 && removed[0] == uid));
    }

    // 반응·댓글 메타 필드만 수정하는지, 그리고 본인 uid만 배열에 추가/삭제하는지 검증
    function isMetaOnlyUpdate() {
      let oldD = resource.data;
      let newD = request.resource.data;
      let uid  = request.auth.uid;

      // penName·commenters 제외 — 이 두 필드는 isMetaOnlyUpdate 경로로 변경 불가
      let isOnlyMeta = newD.diff(oldD).affectedKeys()
        .hasOnly(['likes','tears','shocks','fears','likeCount','commentCount']);

      // likeCount = 배열 합계와 정확히 일치해야 함 (숫자 직접 조작 차단)
      let expectedCount = newD.get('likes', []).size() + newD.get('tears', []).size()
                        + newD.get('shocks',[]).size() + newD.get('fears', []).size();

      // commentCount 는 ±1 이내만 허용
      let c_diff = newD.get('commentCount', 0) - oldD.get('commentCount', 0);

      return isOnlyMeta
          && isValidArrayChange(newD.get('likes',  []), oldD.get('likes',  []), uid)
          && isValidArrayChange(newD.get('tears',  []), oldD.get('tears',  []), uid)
          && isValidArrayChange(newD.get('shocks', []), oldD.get('shocks', []), uid)
          && isValidArrayChange(newD.get('fears',  []), oldD.get('fears',  []), uid)
          && newD.get('likeCount', 0) == expectedCount
          && c_diff >= -1 && c_diff <= 1;
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isCnsaUser();
      allow create: if isCnsaUser()
                    && request.auth.uid == userId
                    && (!('role' in request.resource.data) || request.resource.data.role == 'student')
                    && (!('points' in request.resource.data) || request.resource.data.points == 0);
      allow update: if isCnsaUser()
                    && ((request.auth.uid == userId && roleNotChanged()) || isAdmin());
      allow delete: if isAdmin();
    }

    // ── config ─────────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read: if isCnsaUser();
      allow write: if isAdmin();
    }

    // ── indexes ────────────────────────────────────────────────────────────
    match /indexes/{docId} {
      allow read: if isCnsaUser();
      allow update: if isCnsaUser();
      allow create, delete: if isAdmin();
    }

    // ── posts ──────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isCnsaUser();
      allow create: if isCnsaUser()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.title.size() <= 50
                    && request.resource.data.body.size()  <= 20000
                    && (request.resource.data.get('category','') != '산문'
                        || request.resource.data.body.size() >= 3000)
                    && request.resource.data.keys().hasOnly([
                         'uid','penName','category','title','intro','body',
                         'likeCount','likes','tears','shocks','fears',
                         'commentCount','commenters','createdAt',
                         'docType','targetPostId','targetPostTitle'
                       ]);
      allow update: if isCnsaUser()
                    && (resource.data.uid == request.auth.uid || isAdmin() || isMetaOnlyUpdate());
      allow delete: if isCnsaUser()
                    && (resource.data.uid == request.auth.uid || isAdmin());

      // comments 서브컬렉션
      match /comments/{commentId} {
        allow read: if isCnsaUser();
        allow create: if isCnsaUser()
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.body.size() <= 500
                      && request.resource.data.keys().hasOnly([
                           'uid','penName','body','createdAt','likes','likeCount'
                         ]);
        allow update: if isCnsaUser()
                      && (resource.data.uid == request.auth.uid || isAdmin());
        allow delete: if isCnsaUser()
                      && (resource.data.uid == request.auth.uid || isAdmin());
      }
    }

    // ── penNameRequests ────────────────────────────────────────────────────
    match /penNameRequests/{reqId} {
      allow read: if isAdmin();
      allow create: if isCnsaUser() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── notifications ──────────────────────────────────────────────────────
    match /notifications/{notiId} {
      allow read:   if isCnsaUser() && resource.data.targetUid == request.auth.uid;
      allow create: if isCnsaUser();
      allow update: if isCnsaUser() && resource.data.targetUid == request.auth.uid;
      allow delete: if (isCnsaUser() && resource.data.targetUid == request.auth.uid) || isAdmin();
    }

    // ── archive_2026 ───────────────────────────────────────────────────────
    match /archive_2026/{docId} {
      allow read: if isCnsaUser();
      allow write: if isAdmin();
      match /comments/{commentId} {
        allow read: if isCnsaUser();
        allow write: if isAdmin();
      }
    }

    // ── fallback ───────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
